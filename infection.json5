{
    "$schema": "https://raw.githubusercontent.com/infection/infection/0.32/resources/schema.json",
    "source": {
        "directories": [
            "."
        ],
        "excludes": [
            "vendor",
            "tests",
            ".docker",
            "logs",
            "images",
            "screenshots",
            "coverage",
            "todos"
        ]
    },
    "logs": {
        "text": "infection.log",
        "html": "infection.html",
        "summary": "infection-summary.log"
    },
    "mutators": {
        "@default": true
    },
    "phpUnit": {
        "configDir": "."
    },
    "testFramework": "phpunit",
    "testFrameworkOptions": "--testsuite=Unit",
    "timeout": 30,
    "minMsi": 0,
    "minCoveredMsi": 0
}
