# ===========================================
# PowerClan - .gitignore
# ===========================================

# -------------------------------------------
# Installer Lockfile
# -------------------------------------------
/install.lock
/install.lock.*

# -------------------------------------------
# Dependencies
# -------------------------------------------
/vendor/
/node_modules/

# -------------------------------------------
# Composer
# -------------------------------------------
composer.lock
composer.phar

# -------------------------------------------
# IDE & Editors
# -------------------------------------------
/.idea/
/.vscode/
/.fleet/
/.zed/
/.history/
*.iml
*.sublime-project
*.sublime-workspace
*.code-workspace
.project
.settings/
.buildpath
*.swp
*.swo
*.swn
*~
.*.sw?
.directory
.netrwhist

# -------------------------------------------
# AI / Assistant Tools
# -------------------------------------------
/.claude/
/.cursor/
/.cursorrules
/.aider*
/.serena/
/.mcp.json
CLAUDE.md.local

# -------------------------------------------
# OS Generated Files
# -------------------------------------------
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
desktop.ini
*.lnk

# -------------------------------------------
# Application Configuration (credentials)
# -------------------------------------------
/config.inc.php
/admin/config.inc.php

# -------------------------------------------
# Secrets / Certificates / Keys
# -------------------------------------------
*.pem
*.key
*.p12
*.pfx
*.crt
*.cer
*.csr
*.asc
id_rsa
id_dsa
id_ecdsa
id_ed25519
*.ppk
secrets/
/.secrets
/.htpasswd

# -------------------------------------------
# Logs & Debug
# -------------------------------------------
/logs/*.log
!/logs/.gitkeep
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
lerna-debug.log*
debug.log
error_log
php_errorlog

# -------------------------------------------
# Test Coverage & Reports
# -------------------------------------------
/coverage/
/coverage-report/
/.phpunit.cache/
/.phpunit.result.cache
/phpunit.xml.bak
clover.xml
coverage.xml
coverage.html
coverage.clover
coverage.crap4j.xml
coverage.junit.xml
.phpunit.result.cache

# -------------------------------------------
# Static Analysis Tools
# -------------------------------------------
# PHPStan
/phpstan-cache/
phpstan-baseline.neon
phpstan-baseline.php
# PHP-CS-Fixer
.php-cs-fixer.cache
.php_cs.cache
# Psalm
/psalm-cache/
psalm-baseline.xml
# Rector
/rector-cache/
# PHPCS
.phpcs-cache
phpcs.xml.dist.bak

# -------------------------------------------
# Mutation Testing (Infection)
# -------------------------------------------
infection.log
infection.html
infection-summary.log
infection-cache/

# -------------------------------------------
# Build & Dist
# -------------------------------------------
/build/
/dist/
/public/build/
*.phar

# -------------------------------------------
# Archives & Dumps
# -------------------------------------------
*.tar
*.tar.gz
*.tgz
*.tar.bz2
*.tar.xz
*.zip
*.rar
*.7z
*.gz
*.bz2
*.xz
*.sql.gz
*.sql.bz2
*.dump
*.dump.sql

# -------------------------------------------
# Temporary Files
# -------------------------------------------
*.tmp
*.temp
*.bak
*.backup
*.old
*.orig
*.rej
*.cache
*.pid
*.seed
/tmp/
/var/tmp/
/cache/
/sessions/
/storage/logs/
/storage/framework/cache/
/storage/framework/sessions/

# -------------------------------------------
# Environment Files
# -------------------------------------------
.env
.env.local
.env.*.local
.env.backup
.env.production
.env.development

# -------------------------------------------
# Docker (local overrides)
# -------------------------------------------
docker-compose.override.yml
docker-compose.override.yaml
.docker-sync/

# -------------------------------------------
# Deprecated / Legacy
# -------------------------------------------
/gnulicense.txt
/Installationsguide/

# -------------------------------------------
# User Uploads & Generated Media
# -------------------------------------------
/images/members/*
!/images/members/.gitkeep
/images/wars/*
!/images/wars/.gitkeep
/uploads/
/public/uploads/

# -------------------------------------------
# User-specific PHP files
# -------------------------------------------
*.local
*.user
.user.ini
auth.json
