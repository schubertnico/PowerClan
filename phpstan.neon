parameters:
    level: 8
    paths:
        - .
    excludePaths:
        - vendor
        - .docker
        - logs
        - tests
        # Optional – existieren nur lokal, nicht im CI (CI-Runner kennt sie nicht)
        - .idea (?)
        - coverage (?)
        - coverage-report (?)
        - .phpunit.cache (?)
        - .claude (?)
    bootstrapFiles:
        - phpstan-bootstrap.php
    treatPhpDocTypesAsCertain: false
