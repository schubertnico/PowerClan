<?xml version="1.0"?>
<psalm
    errorLevel="4"
    resolveFromConfigFile="true"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xmlns="https://getpsalm.org/schema/config"
    xsi:schemaLocation="https://getpsalm.org/schema/config vendor/vimeo/psalm/config.xsd"
    findUnusedBaselineEntry="true"
    findUnusedCode="false"
>
    <projectFiles>
        <directory name="." />
        <ignoreFiles>
            <!-- Nur Verzeichnisse auflisten, die IMMER existieren. Psalm kann
                 keine optionalen Pfade. Lokal existierende Artefakte wie
                 .idea, coverage, .phpunit.cache, .claude werden zur Psalm-
                 Laufzeit im CI nicht mitanalysiert, weil sie dort nicht
                 existieren. -->
            <directory name="vendor" />
            <directory name=".docker" />
            <directory name="docs" />
            <directory name="todos" />
            <directory name="screenshots" />
            <!-- Tests nutzen PHPUnit-Attribute, die Psalm nicht kennt -->
            <directory name="tests" />
        </ignoreFiles>
    </projectFiles>

    <issueHandlers>
        <!-- Legacy-Code Toleranz -->
        <MixedAssignment errorLevel="suppress" />
        <MixedArgument errorLevel="suppress" />
        <MixedArrayAccess errorLevel="suppress" />
        <MixedMethodCall errorLevel="suppress" />
        <MixedReturnStatement errorLevel="suppress" />

        <!-- Globale Variablen (Legacy) -->
        <UndefinedGlobalVariable errorLevel="suppress" />

        <!-- Superglobals -->
        <PossiblyUndefinedArrayOffset errorLevel="suppress" />

        <!-- Array Offsets (Legacy $settings array) -->
        <InvalidArrayOffset errorLevel="suppress" />

        <!-- $settings kann leer sein (wird per getsettings() befüllt) -->
        <EmptyArrayAccess errorLevel="suppress" />

        <!-- config.inc.php wird per Installer erzeugt; in CI nicht vorhanden -->
        <MissingFile errorLevel="suppress" />

        <!-- Redundante Casts in Legacy-Code nicht blockierend -->
        <RedundantCast errorLevel="info" />
        <RedundantCastGivenDocblockType errorLevel="info" />

        <!-- mysqli_fetch_array: zweites Argument ist optional mit Default -->
        <InvalidArgument>
            <errorLevel type="suppress">
                <referencedFunction name="mysqli_fetch_array" />
            </errorLevel>
        </InvalidArgument>

        <!-- Redundante Bedingungen -->
        <RedundantCondition errorLevel="info" />
        <TypeDoesNotContainType errorLevel="info" />
        <TypeDoesNotContainNull errorLevel="info" />

        <!-- Legacy Doppelte Funktionen (admin/ hat eigene Kopien) -->
        <DuplicateFunction errorLevel="suppress" />

        <!-- PHP 8.4 Override Attribute (nicht kritisch) -->
        <MissingOverrideAttribute errorLevel="info" />

        <!-- Dead Code Info -->
        <NoValue errorLevel="info" />
    </issueHandlers>
</psalm>
